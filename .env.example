# ─────────────────────────────────────────────────────────
# DECISION LEDGER — Environment Variables
# ─────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values (never commit .env — it's in .gitignore)
#   3. Each service reads its own variables
#
# WHERE TO GET THESE:
#   Supabase  → https://app.supabase.com → your project → Settings → API
#   Anthropic → https://console.anthropic.com → API Keys
# ─────────────────────────────────────────────────────────

# ── Supabase (required for everything)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# NOTE: ANON_KEY is safe in the frontend (respects Row Level Security)
# NOTE: SERVICE_ROLE_KEY bypasses all security — backend only, never frontend

# ── AI Providers (model gateway)
ANTHROPIC_API_KEY=sk-ant-your-key-here
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ── Redis (caching layer for model gateway)
REDIS_URL=redis://localhost:6379

# ── FastAPI backend
API_PORT=8000
API_ENV=development
# Options: development | staging | production

# ── Next.js frontend
# These NEXT_PUBLIC_ variables are exposed to the browser — only put safe values here
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_API_URL=http://localhost:8000
